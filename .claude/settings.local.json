{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Write(*)",
      "Read(*)",
      "Edit(*)",
      "Agent(*)",
      "Glob(*)",
      "Grep(*)",
      "ToolSearch",
      "Skill(*)",
      "TaskCreate",
      "NotebookEdit",
      "SendMessage",
      "RemoteTrigger",
      "CronCreate",
      "TeamCreate",
      "Bash(*)",
      "WebSearch",
      "Bash",
      "WebFetch(*)",
      "WebFetch"
    ]
  },
  "enabledPlugins": {},
  "permissionMode": "bypassPermissions",
  "language": "简体中文"
}
