# =============================================================================
# LLM Chat Application Configuration Template
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置
# cp .env.example .env

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://llmchat:your_password@localhost:5432/llmchat
POSTGRES_USER=llmchat
POSTGRES_PASSWORD=your_password
POSTGRES_DB=llmchat
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_PORT=8001
BACKEND_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# CORS (comma-separated origins)
# -----------------------------------------------------------------------------
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Encryption key for API keys (64 hex characters = 32 bytes)
# 生成新密钥: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
